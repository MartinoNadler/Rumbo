# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres connection strings (Project Settings -> Database -> Connection string)
# DATABASE_URL: pooled connection (port 6543), authenticated as the restricted
#   "app_user" role created by prisma/rls.sql. Used by Prisma Client at runtime
#   so RLS policies are actually enforced.
# DIRECT_URL: direct connection (port 5432), authenticated as the default
#   "postgres" (owner) role. Used only by `prisma migrate`.
DATABASE_URL=
DIRECT_URL=
