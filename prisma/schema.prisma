// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivitySource {
  STRAVA
  MANUAL
}

enum Role {
  PROFESSOR
  STUDENT
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  nickname  String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  stravaAccount StravaAccount?
  activities    Activity[]

  groupsOwned      Group[]          @relation("ProfessorGroups")
  membership       Membership?
  assignedWorkouts PlannedWorkout[] @relation("AssignedByProfessor")
  plannedWorkouts  PlannedWorkout[] @relation("StudentWorkouts")
  posts            Post[]
  reactions        Reaction[]
  goals            Goal[]
}

model Group {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  professorId String
  professor   User     @relation("ProfessorGroups", fields: [professorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  memberships     Membership[]
  plannedWorkouts PlannedWorkout[]
  posts           Post[]
}

model Membership {
  id                         String   @id @default(uuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId                    String
  group                      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  metricsSharedWithProfessor Boolean  @default(false)
  joinedAt                   DateTime @default(now())
}

model PlannedWorkout {
  id                   String    @id @default(uuid())
  groupId              String
  group                Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId            String
  student              User      @relation("StudentWorkouts", fields: [studentId], references: [id], onDelete: Cascade)
  assignedById         String
  assignedBy           User      @relation("AssignedByProfessor", fields: [assignedById], references: [id], onDelete: Cascade)
  date                 DateTime
  type                 String
  description          String?
  targetDistanceMeters Float?
  targetDurationSec    Int?
  createdAt            DateTime  @default(now())

  @@index([studentId, date])
}

model Post {
  id        String     @id @default(uuid())
  groupId   String
  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())
  reactions Reaction[]

  @@index([groupId, createdAt])
}

model Reaction {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
}

model Goal {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  targetValue Float
  deadline    DateTime?
  createdAt   DateTime  @default(now())
}

model StravaAccount {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stravaAthleteId String    @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
}

model Activity {
  id                  String         @id @default(uuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              ActivitySource @default(STRAVA)
  externalId          String?
  type                String
  startDate           DateTime
  distanceMeters      Float
  movingTimeSec        Int
  elapsedTimeSec       Int
  avgPaceSecPerKm      Float?
  avgHeartRate         Float?
  maxHeartRate         Float?
  avgCadence           Float?
  elevationGainMeters  Float?
  calories             Float?
  splits               Json?
  gpsTrack             Json?
  createdAt            DateTime       @default(now())

  @@unique([userId, source, externalId])
  @@index([userId, startDate])
}
