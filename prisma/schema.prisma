// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime queries: pooled connection, authenticated as the restricted
  // "app_user" role so Postgres RLS policies actually apply (see prisma/rls.sql).
  url       = env("DATABASE_URL")
  // Migrations: direct connection, authenticated as the table-owning role
  // (e.g. the default Supabase "postgres" user).
  directUrl = env("DIRECT_URL")
}

enum ActivitySource {
  MANUAL
  FIT
  TCX
  GPX
  CSV
  STRAVA
}

enum Role {
  PROFESSOR
  STUDENT
}

enum WorkoutStatus {
  PENDING
  DONE
  SKIPPED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  nickname  String?
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  stravaAccount StravaAccount?
  activities    Activity[]

  groupsOwned      Group[]          @relation("ProfessorGroups")
  membership       Membership?
  assignedWorkouts PlannedWorkout[] @relation("AssignedByProfessor")
  plannedWorkouts  PlannedWorkout[] @relation("StudentWorkouts")
  posts            Post[]
  comments         Comment[]
  reactions        Reaction[]
  goals            Goal[]
  userBadges       UserBadge[]
}

model Group {
  id          String   @id @default(uuid())
  name        String
  inviteCode  String   @unique
  professorId String
  professor   User     @relation("ProfessorGroups", fields: [professorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  memberships     Membership[]
  plannedWorkouts PlannedWorkout[]
  posts           Post[]
}

model Membership {
  id                         String   @id @default(uuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupId                    String
  group                      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  metricsSharedWithProfessor Boolean  @default(false)
  joinedAt                   DateTime @default(now())

  @@index([groupId])
}

model PlannedWorkout {
  id                   String    @id @default(uuid())
  groupId              String
  group                Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId            String
  student              User      @relation("StudentWorkouts", fields: [studentId], references: [id], onDelete: Cascade)
  assignedById         String
  assignedBy           User      @relation("AssignedByProfessor", fields: [assignedById], references: [id], onDelete: Cascade)
  date                 DateTime
  type                 String
  goal                 String?
  description          String?
  intensity            String?
  targetDistanceMeters Float?
  targetDurationSec    Int?
  status               WorkoutStatus @default(PENDING)
  createdAt            DateTime  @default(now())

  @@index([studentId, date])
}

model Post {
  id        String     @id @default(uuid())
  groupId   String
  group     Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())
  comments  Comment[]
  reactions Reaction[]

  @@index([groupId, createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model Reaction {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
}

model Goal {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  targetValue Float
  deadline    DateTime?
  createdAt   DateTime  @default(now())
}

model Badge {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model StravaAccount {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stravaAthleteId String    @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
}

model Activity {
  id                  String         @id @default(uuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              ActivitySource @default(MANUAL)
  externalId          String?
  type                String
  startDate           DateTime
  distanceMeters      Float
  movingTimeSec       Int
  elapsedTimeSec      Int
  avgPaceSecPerKm     Float?
  avgHeartRate        Float?
  maxHeartRate        Float?
  avgCadence          Float?
  elevationGainMeters Float?
  calories            Float?
  splits              Json?
  gpsTrack            Json?
  feeling             String?
  notes               String?
  createdAt           DateTime       @default(now())

  @@unique([userId, source, externalId])
  @@index([userId, startDate])
}
