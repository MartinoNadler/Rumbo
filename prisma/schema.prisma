// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivitySource {
  STRAVA
  MANUAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  createdAt DateTime @default(now())

  stravaAccount StravaAccount?
  activities    Activity[]
}

model StravaAccount {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stravaAthleteId String    @unique
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())
}

model Activity {
  id                  String         @id @default(uuid())
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  source              ActivitySource @default(STRAVA)
  externalId          String?
  type                String
  startDate           DateTime
  distanceMeters      Float
  movingTimeSec        Int
  elapsedTimeSec       Int
  avgPaceSecPerKm      Float?
  avgHeartRate         Float?
  maxHeartRate         Float?
  avgCadence           Float?
  elevationGainMeters  Float?
  calories             Float?
  splits               Json?
  gpsTrack             Json?
  createdAt            DateTime       @default(now())

  @@unique([userId, source, externalId])
  @@index([userId, startDate])
}
